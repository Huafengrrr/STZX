<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- 隐藏的底层相机预览 (必须保留) -->
    <com.jiangdg.ausbc.widget.AspectRatioTextureView
        android:id="@+id/camera_view"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0" />

    <!-- 炫酷的带阴影绿色 FPS 显示 -->
    <TextView
        android:id="@+id/fps_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:textColor="#00FF00"
        android:textSize="24sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="3"
        android:shadowDy="3"
        android:shadowRadius="5"
        android:text="FPS: 0" />

    <!-- 🌟 双目上下分屏布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 上半屏：左眼画面 + 左眼红框层 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                android:id="@+id/iv_left_eye"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <com.example.myapplication1.OverlayView
                android:id="@+id/overlay_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- 下半屏：右眼画面 + 右眼红框层 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="2dp">

            <ImageView
                android:id="@+id/iv_right_eye"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <com.example.myapplication1.OverlayView
                android:id="@+id/overlay_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>